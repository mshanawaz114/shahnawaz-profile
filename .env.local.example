# ─────────────────────────────────────────────────────────────
# Groq API — https://console.groq.com/keys  (free tier)
# Required for the "Ask Shahnawaz" chatbot route.
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=

# Optional — which Llama model to use. Defaults to llama-3.1-8b-instant.
# Options:  llama-3.1-8b-instant  |  llama-3.1-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant

# Optional — used for sitemap + OG metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
